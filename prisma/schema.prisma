// Lakhan Bhandar POS System - Database Schema
// Compatible with Supabase/PostgreSQL and SQLite for development

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// PRODUCTS & INVENTORY
// ============================================================================

model Product {
  id            String   @id @default(cuid())
  barcode       String?  @unique // Nullable for non-barcoded items (vegetables, loose items)
  name          String
  nameBn        String?  @map("name_bn") // Bengali name
  category      String   @default("General")
  buyingPrice   Decimal  @default(0) @map("buying_price")
  sellingPrice  Decimal  @default(0) @map("selling_price")
  unit          String   @default("piece") // piece, kg, gram, liter, packet
  currentStock  Float    @default(0) @map("current_stock")
  minStockLevel Float    @default(5) @map("min_stock_level")
  isActive      Boolean  @default(true) @map("is_active") // Soft delete
  imageUrl      String?  @map("image_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  stockHistory  StockHistory[]

  @@index([isActive])
  @@index([category, isActive])
  @@index([name])
  @@map("products")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  nameBn      String?  @map("name_bn")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

model StockHistory {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  changeType  String // "purchase", "sale", "adjustment", "return"
  quantity    Float // Positive for addition, negative for deduction
  reason      String?
  referenceId String?  @map("reference_id") // Sale ID or Purchase ID
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
  @@map("stock_history")
}

// ============================================================================
// CUSTOMERS & LEDGER (Due/Baki System)
// ============================================================================

model Customer {
  id             String   @id @default(cuid())
  name           String
  phone          String?  @unique
  address        String?
  totalDue       Decimal  @default(0) @map("total_due") // Running total of outstanding balance (owes store)
  totalPaid      Decimal  @default(0) @map("total_paid") // Total amount paid historically
  prepaidBalance Decimal  @default(0) @map("prepaid_balance") // Prepaid/credit balance (store owes customer)
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  ledgerEntries LedgerEntry[]
  sales         Sale[]

  @@index([phone])
  @@map("customers")
}

model LedgerEntry {
  id           String   @id @default(cuid())
  customerId   String   @map("customer_id")
  entryType    String // "credit" (customer owes more), "debit" (customer paid)
  amount       Decimal
  balanceAfter Decimal  @map("balance_after") // Balance after this transaction
  description  String?
  referenceId  String?  @map("reference_id") // Sale ID or Payment ID
  createdAt    DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
  @@index([customerId, createdAt])
  @@map("ledger_entries")
}

// ============================================================================
// SALES & BILLING
// ============================================================================

model Sale {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique @map("invoice_number")
  customerId    String?  @map("customer_id")
  userId        String?  @map("user_id") // Track which user created this sale
  subtotal      Decimal  @default(0)
  discount      Decimal  @default(0)
  tax           Decimal  @default(0)
  totalAmount   Decimal  @default(0) @map("total_amount")
  amountPaid    Decimal  @default(0) @map("amount_paid")
  paymentMethod String   @default("Cash") @map("payment_method") // Cash, UPI, Due
  paymentStatus String   @default("Paid") @map("payment_status") // Paid, Partial, Due
  status        String   @default("Completed") // Completed, Cancelled, Refunded, PartialReturn
  cashAmount    Decimal? @map("cash_amount")
  upiAmount     Decimal? @map("upi_amount")
  notes         String?
  offlineSynced Boolean  @default(true) @map("offline_synced") // For offline-first
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  customer Customer?    @relation(fields: [customerId], references: [id])
  user     User?        @relation(fields: [userId], references: [id])
  items    SaleItem[]
  returns  SaleReturn[]

  @@index([customerId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@map("sales")
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String   @map("sale_id")
  productId   String   @map("product_id")
  productName String   @map("product_name") // Snapshot at time of sale
  quantity    Float
  unitPrice   Decimal  @map("unit_price") // Price at time of sale
  totalPrice  Decimal  @map("total_price")
  createdAt   DateTime @default(now()) @map("created_at")

  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product          @relation(fields: [productId], references: [id])
  returnItems SaleReturnItem[]

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ============================================================================
// PARTIAL RETURNS
// ============================================================================

model SaleReturn {
  id           String   @id @default(cuid())
  saleId       String   @map("sale_id")
  userId       String?  @map("user_id")
  refundAmount Decimal  @map("refund_amount")
  refundMethod String   @default("Cash") @map("refund_method") // Cash, Prepaid
  reason       String?
  createdAt    DateTime @default(now()) @map("created_at")

  sale  Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  user  User?            @relation(fields: [userId], references: [id])
  items SaleReturnItem[]

  @@index([saleId])
  @@index([createdAt])
  @@map("sale_returns")
}

model SaleReturnItem {
  id           String   @id @default(cuid())
  saleReturnId String   @map("sale_return_id")
  saleItemId   String   @map("sale_item_id")
  productId    String   @map("product_id")
  productName  String   @map("product_name")
  quantity     Float
  unitPrice    Decimal  @map("unit_price")
  totalPrice   Decimal  @map("total_price")
  createdAt    DateTime @default(now()) @map("created_at")

  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  saleItem   SaleItem   @relation(fields: [saleItemId], references: [id])

  @@index([saleReturnId])
  @@index([saleItemId])
  @@map("sale_return_items")
}

// ============================================================================
// PURCHASES (Restocking from Suppliers)
// ============================================================================

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  email     String?
  gstNumber String?  @map("gst_number")
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchases Purchase[]
  expenses  Expense[]

  @@map("suppliers")
}

model Purchase {
  id            String   @id @default(cuid())
  supplierId    String?  @map("supplier_id")
  invoiceNumber String?  @map("invoice_number")
  totalAmount   Decimal  @default(0) @map("total_amount")
  paymentStatus String   @default("Pending") @map("payment_status") // Paid, Pending, Partial
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@index([supplierId])
  @@index([createdAt])
  @@map("purchases")
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String   @map("purchase_id")
  productId   String   @map("product_id")
  productName String   @map("product_name")
  quantity    Float
  buyingPrice Decimal  @map("buying_price")
  totalPrice  Decimal  @map("total_price")
  createdAt   DateTime @default(now()) @map("created_at")

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_items")
}

// ============================================================================
// SYNC QUEUE (Offline-First Architecture)
// ============================================================================

model SyncQueue {
  id             String    @id @default(cuid())
  idempotencyKey String    @unique @map("idempotency_key") // UUID v4 - CRITICAL for preventing duplicates
  entityType     String    @map("entity_type") // sale:create, customer:update, etc.
  entityId       String?   @map("entity_id")
  action         String // sync action type
  payload        String // JSON stringified data
  result         String? // JSON stringified result (for idempotency cache)
  synced         Boolean   @default(false)
  syncedAt       DateTime? @map("synced_at")
  retryCount     Int       @default(0) @map("retry_count")
  error          String?
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([synced])
  @@index([idempotencyKey])
  @@index([entityType])
  @@map("sync_queue")
}

// ============================================================================
// APP SETTINGS & CONFIGURATION
// ============================================================================

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ============================================================================
// USERS & AUTHENTICATION
// ============================================================================

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String?  @unique
  password  String
  name      String
  phone     String?
  role                   UserRole @default(VIEWER)
  isActive               Boolean  @default(true) @map("is_active")
  requiresPasswordChange Boolean  @default(false) @map("requires_password_change")
  failedLoginAttempts    Int      @default(0) @map("failed_login_attempts")
  lockedUntil            DateTime? @map("locked_until")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  // Relations
  sales       Sale[]
  saleReturns SaleReturn[]
  auditLogs   AuditLog[]

  @@map("users")
}

// ============================================================================
// ROLE PERMISSIONS
// ============================================================================

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // e.g., "users.create", "sales.view", "reports.export"
  description String?
  category    String // e.g., "users", "sales", "products", "reports", "settings"
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

// Define default role permissions
model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

// ============================================================================
// EXPENSES
// ============================================================================

model Expense {
  id           String    @id @default(cuid())
  amount       Decimal
  category     String
  notes        String?
  date         DateTime  @default(now())
  supplierId   String?   @map("supplier_id")
  supplierName String?   @map("supplier_name")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([date])
  @@index([supplierId])
  @@map("expenses")
}

// ============================================================================
// AUDIT LOG
// ============================================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String   // e.g., "CREATE_PRODUCT", "DELETE_SALE", "UPDATE_CUSTOMER", "LOGIN"
  entityType  String   // e.g., "Product", "Sale", "Customer", "User"
  entityId    String?  @map("entity_id")
  details     String?  // JSON stringified details of the change
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
